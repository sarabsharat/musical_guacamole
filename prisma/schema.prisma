datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  platform_admin
  restaurant_owner
  nutritionist_auditor
  jfda_officer
}

enum CertStatus {
  NONE
  PENDING
  ACTIVE
  REVOKED
}

enum CertLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
}

enum RecipeStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum NotificationType {
  SYSTEM
  CERT_APPROVAL
  CERT_REJECTION
}

enum DraftStatus {
  PROCESSING
  RESOLVED
  FAILED
}

model User {
  id            Int         @id @default(autoincrement())
  email         String      @unique
  password_hash String?
  phone_number  String?
  full_name     String?
  name          String?
  image         String?
  emailVerified DateTime?
  role          Role?
  created_at    DateTime    @default(now())
  is_active     Boolean     @default(true)

  restaurant    Restaurant?

  auditLogs     AuditLog[]
  reset_tokens  PasswordResetToken[]
  accounts      Account[]
  sessions      Session[]
}

model Restaurant {
  id Int @id @default(autoincrement())

  slug          String  @unique // e.g., "burger-lab" for burger-lab.yourapp.jo
  custom_domain String? @unique // e.g., "nutrition.burgerlab.com"
  plan_tier     String  @default("free")
  business_name String
  address_line  String
  cert_status   CertStatus              @default(NONE)
  cert_level    CertLevel               @default(LEVEL_1)
  owner_id      Int                     @unique
  owner         User                    @relation(fields: [owner_id], references: [id])
  recipes       Recipe[]
  profile       KitchenControlProfile[]
  recipeDrafts  RecipeDraft[]
  auditLogs AuditLog[]
  estimated_recipe_count Int?    // how many recipes they already have
  delivery_apps         String[]
  logo_url           String?   // URL to the restaurant logo
  background_image_url String?
}

model IngredientReference {
  id             Int                @id @default(autoincrement())
  name           String             @unique
  name_ar        String
  calories_per_g Decimal
  protein_per_g  Decimal
  carbs_per_g    Decimal
  fat_per_g      Decimal
  allergens      String[]           @default([])
  recipe_links   RecipeIngredient[]
}

model Recipe {
  id                 Int                @id @default(autoincrement())
  restaurant_id      Int
  restaurant         Restaurant         @relation(fields: [restaurant_id], references: [id])
  meal_name          String
  image_url          String
  preparation_notes  String
  calories           Decimal
  protein            Decimal
  carbs              Decimal
  total_fat          Decimal
  status             RecipeStatus       @default(PENDING)
  rejection_reason   String?
  detected_allergens String[]           @default([])
  ingredients        RecipeIngredient[]
  versions           RecipeVersion[]
  auditLogs AuditLog[]
}

model RecipeIngredient {
  id                 Int                 @id @default(autoincrement())
  recipe_id          Int
  recipe             Recipe              @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  ingredient_id      Int
  ingredient_item    IngredientReference @relation(fields: [ingredient_id], references: [id])
  user_stated_amount String // e.g., "2 pieces", "a splash"
  normalized_grams   Decimal // Scaled weight after mapping
}

model KitchenControlProfile {
  id           Int @id @default(autoincrement())
  restaurantId Int @unique

  // Specific toggles for the two controls you want
  hasDedicatedAllergenZones Boolean @default(false)
  usesStandardizedRecipes   Boolean @default(false)
  has_allergen_separation   Boolean @default(false)
  uses_calorie_tracking     Boolean @default(false)
  has_cross_contamination_plan Boolean @default(false)

  updatedAt  DateTime   @updatedAt
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

model RecipeVersion {
  id         Int      @id @default(autoincrement())
  recipe_id  Int
  recipe     Recipe   @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  snapshot   Json // Immutable copy of the approved recipe data
  created_at DateTime @default(now())
}

model RecipeDraft {
  id             Int         @id @default(autoincrement())
  restaurant_id  Int
  restaurant     Restaurant  @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  raw_input_text String
  image_url      String?
  extracted_json Json? // Intermediate JSON payload from the AI extraction pipeline
  status         DraftStatus @default(PROCESSING)
  error_message  String?
  created_at     DateTime    @default(now())
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  actor_id      Int
  actor         User     @relation(fields: [actor_id], references: [id])
  restaurant_id Int?
  restaurant    Restaurant? @relation(fields: [restaurant_id], references: [id])
  recipe_id     Int?
  recipe        Recipe?  @relation(fields: [recipe_id], references: [id])
  action        String
  payload       Json?
  created_at    DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             Int     // Matches the Int type of User.id
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int      // Matches the Int type of User.id
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
